    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "storybook": "^8.0.0",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.8.3",
    "vitest": "^1.6.0"
