    "@angular/material": "^17.3.0",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@ngneat/hot-toast": "^6.0.0",
    "@ngrx/component-store": "^17.2.0",
    "@ngrx/operators": "^17.2.0",
    "@sentry/angular": "^10.49.0",
    "animate.css": "^4.1.1",
    "aos": "^2.3.4",
    "gsap": "^3.12.0",
    "lucide-angular": "^0.456.0",
    "material-icons": "^1.13.14",
    "ngx-skeleton-loader": "^9.0.0",
