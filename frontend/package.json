{
  "name": "cyber-vault-frontend",
  "version": "0.6.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run --reporter=verbose --reporter=junit --outputFile=test-results/results.xml",
    "test:coverage": "vitest run --coverage --reporter=verbose --reporter=junit --outputFile=test-results/results.xml",
    "test:e2e": "playwright test",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "compodoc": "compodoc -p tsconfig.doc.json --theme material",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
