# === PRODUCTION — copier en .env et remplir les valeurs ===
# Ne jamais committer ce fichier avec de vraies valeurs

# Application
APP_ENV=production
SECRET_KEY=CHANGEZ_MOI_64_CARACTERES_MINIMUM_GENERE_AVEC_openssl_rand_hex_32

# Base de données (Docker Compose interne)
DB_USER=cybervault
DB_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT
DB_NAME=cybervault_prod

# CORS — remplacer par votre domaine
ALLOWED_ORIGINS=["https://VOTRE_DOMAINE.fr"]
FRONTEND_URL=https://VOTRE_DOMAINE.fr

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=APP_PASSWORD_GMAIL
SMTP_FROM=noreply@VOTRE_DOMAINE.fr

# Admin
ADMIN_API_KEY=CHANGEZ_MOI_CLE_ADMIN_FORTE

# Optionnel
SENTRY_DSN=
HIBP_API_KEY=
