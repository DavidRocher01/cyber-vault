# === PRODUCTION AWS — copier en .env et remplir les valeurs ===
# Les secrets sensibles sont stockés dans AWS Secrets Manager
# Ne jamais committer ce fichier avec de vraies valeurs

# Application
APP_ENV=production
SECRET_KEY=CHANGEZ_MOI_64_CHARS_MINIMUM   # openssl rand -hex 32

# Base de données — RDS PostgreSQL t4g.micro (eu-west-3)
# Format : postgresql+asyncpg://user:password@rds-endpoint.eu-west-3.rds.amazonaws.com:5432/dbname
DATABASE_URL=postgresql+asyncpg://cybervault:PASSWORD@ENDPOINT.rds.amazonaws.com:5432/cybervault_prod

# CORS — domaine CloudFront ou domaine custom
ALLOWED_ORIGINS=["https://cyberscanapp.com"]
FRONTEND_URL=https://cyberscanapp.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=APP_PASSWORD_GMAIL
SMTP_FROM=noreply@cyberscanapp.com

# Admin
ADMIN_API_KEY=CHANGEZ_MOI_CLE_ADMIN_FORTE

# Optionnel
SENTRY_DSN=
HIBP_API_KEY=
