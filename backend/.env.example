# ============================================
# APPLICATION
# ============================================
APP_NAME=Cyber-Vault
APP_ENV=production  # development | staging | production
SECRET_KEY=  # generate: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/cybervault

# ============================================
# CORS / FRONTEND
# ============================================
ALLOWED_ORIGINS=["https://cyberscanapp.com"]
FRONTEND_URL=https://cyberscanapp.com

# ============================================
# SÉCURITÉ
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
ADMIN_API_KEY=  # generate: openssl rand -hex 32

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=https://xxx@sentry.io/projet

# ============================================
# STRIPE (LIVE en prod, TEST en staging)
# ============================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
ADDON_EXTRA_SITES_STRIPE_PRICE_ID=price_xxx
ADDON_EXTRA_SITES_COUNT=5
ADDON_EXTRA_SITES_PRICE_EUR=900

# ============================================
# EMAIL — Resend (préféré)
# ============================================
RESEND_API_KEY=re_xxx
RESEND_FROM=CyberScan <no-reply@cyberscanapp.com>

# ============================================
# EMAIL — SMTP (fallback local)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================
# CONTACT
# ============================================
CONTACT_EMAIL=contact@cyberscanapp.com

# ============================================
# AWS S3
# ============================================
S3_BUCKET_NAME=cyberscan-uploads
AWS_REGION=eu-west-3
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (env vars standard ou IAM role ECS)

# ============================================
# HIBP (HaveIBeenPwned breach checker)
# ============================================
HIBP_API_KEY=  # https://haveibeenpwned.com/API/Key

# ============================================
# PHISHING SIMULATION
# ============================================
PHISHING_BASE_URL=https://sim.cyberscanapp.com
PHISHING_FROM_EMAIL=no-reply@cyberscanapp.com
PHISHING_FROM_NAME=CyberScan Exercise
PHISHING_BATCH_SIZE=20
PHISHING_TRACKING_TTL_DAYS=30
