# ============================================
# Caddyfile — Staging Oracle Cloud
# ============================================
#
# HTTPS automatique Let's Encrypt + Basic Auth
# Routes:
#   staging.cyberscanapp.com       → frontend nginx (Angular SPA)
#   api-staging.cyberscanapp.com   → backend FastAPI
#
# Génération du hash Basic Auth :
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext "MonMDP"
#
# ATTENTION : chaque $ dans le hash bcrypt doit être doublé ($$)
# Exemple : $2a$14$xyz → $$2a$$14$$xyz

{
    email contact@cyberscanapp.com

    servers {
        protocols h1 h2 h3
    }
}

# ============================================
# Frontend Angular
# ============================================
staging.cyberscanapp.com {

    basicauth /* {
        # REMPLACER : votre_user et hash bcrypt ($ doublés)
        rocher $$2a$$14$$CHANGE_ME_bcrypt_hash
    }

    header X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Cache-Control "no-store"
        -Server
        -X-Powered-By
    }

    encode gzip zstd

    reverse_proxy frontend:80 {
        transport http {
            response_header_timeout 30s
            dial_timeout 5s
        }
    }

    log {
        output file /data/access-staging.log {
            roll_size 100MB
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }
}

# ============================================
# Backend API
# ============================================
api-staging.cyberscanapp.com {

    request_body {
        max_size 10MB
    }

    # Webhook Stripe — pas de Basic Auth (signature vérifiée par l'app)
    @stripe_webhook path /webhooks/stripe /webhooks/stripe/*
    handle @stripe_webhook {
        header X-Robots-Tag "noindex, nofollow"
        reverse_proxy backend:8000 {
            transport http {
                response_header_timeout 60s
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Health endpoint public (monitoring / smoke test CI)
    @health path /health /health/
    handle @health {
        reverse_proxy backend:8000
    }

    # Tout le reste : Basic Auth
    handle {
        basicauth /* {
            rocher $$2a$$14$$CHANGE_ME_bcrypt_hash
        }

        header X-Robots-Tag "noindex, nofollow"

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "DENY"
            Referrer-Policy "strict-origin-when-cross-origin"
            -Server
        }

        encode gzip zstd

        reverse_proxy backend:8000 {
            transport http {
                response_header_timeout 60s
                dial_timeout 10s
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    log {
        output file /data/access-staging-api.log {
            roll_size 100MB
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }
}
