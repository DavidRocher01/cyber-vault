# ============================================
# Variables d'environnement — Staging Oracle Cloud
# ============================================
# IMPORTANT :
#  - Copier ce fichier en .env
#  - Compléter toutes les valeurs CHANGE_ME
#  - chmod 600 .env
#  - NE JAMAIS COMMITER LE .env

# ============================================
# GitHub / Registry
# ============================================
GITHUB_OWNER=DavidRocher01
VERSION=staging

# ============================================
# Database
# ============================================
POSTGRES_DB=cybervault_staging
POSTGRES_USER=cybervault

# Générer avec : openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME

# ============================================
# Sécurité
# ============================================
# Générer avec : openssl rand -base64 64 | tr -d '\n'
# DOIT être différent de la prod
SECRET_KEY=CHANGE_ME

# ============================================
# Domaines
# ============================================
STAGING_DOMAIN=staging.cyberscanapp.com
API_STAGING_DOMAIN=api-staging.cyberscanapp.com

# ============================================
# Stripe — TEST MODE OBLIGATOIRE
# ============================================
# Tableau de bord Stripe → Mode TEST → Clés API
STRIPE_TEST_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_TEST_WEBHOOK_SECRET=whsec_CHANGE_ME

# ============================================
# Email transactionnel (Resend)
# ============================================
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM=CyberScan Staging <no-reply@cyberscanapp.com>
CONTACT_EMAIL=contact@cyberscanapp.com

# ============================================
# Dark Web — HaveIBeenPwned
# ============================================
HIBP_API_KEY=CHANGE_ME

# ============================================
# Phishing simulation
# ============================================
# Domaine Resend vérifié utilisé comme expéditeur des mails de simulation
PHISHING_FROM_EMAIL=no-reply@cyberscanapp.com
PHISHING_FROM_NAME=CyberScan Staging

# ============================================
# RSSI — Stockage S3 livrables (optionnel)
# ============================================
# Laisser vide pour désactiver l'upload S3
S3_BUCKET_NAME=
AWS_REGION=eu-west-3

# ============================================
# Admin
# ============================================
# Générer avec : openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME

# ============================================
# Observabilité (optionnel)
# ============================================
SENTRY_DSN_STAGING=
